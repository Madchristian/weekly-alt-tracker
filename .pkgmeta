package-as: WeeklyAltTracker

enable-nolib-creation: no

# Kanonische kumulative Release-Historie statt automatisch erzeugter Commitliste.
# Die skalare Form ist die gemeinsame Schnittmenge des BigWigs-Packagers und
# des CurseForge-Repository-Packagers; die verschachtelte BigWigs-Form wird von
# CurseForge ignoriert.
manual-changelog: CHANGELOG.md

ignore:
  - .github
  - .gitignore
  - .pkgmeta
  - .claude
  - CLAUDE.md
  - artwork
  - backups
  - design
  - dist
  - releases
  - tools
  - wago
  - curseforge
  - Media/README.md
